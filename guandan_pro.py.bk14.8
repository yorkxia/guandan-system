@app.route('/save/<int:mid>', methods=['POST'])
def save(mid):
    m = Match.query.get(mid); t1 = Team.query.get(m.team_a_id); t2 = Team.query.get(m.team_b_id)
    sa, sb = int(request.form.get('sa')), int(request.form.get('sb'))
    t1.round_score += sa; t2.round_score += sb
    if sa > sb: t1.current_score += 3
    elif sb > sa: t2.current_score += 3
    else: t1.current_score += 1; t2.current_score += 1
    m.is_completed = True; t1.history_opponents = (t1.history_opponents + f",{t2.id}").strip(','); t2.history_opponents = (t2.history_opponents + f",{t1.id}").strip(',')
    db.session.commit(); log_act("录入成绩", f"轮{m.round_no}-桌{m.table_no}: {sa}-{sb}", m.tournament_id); return redirect(url_for('matches'))

@app.route('/next_r')
def next_r():
    t = get_active_t(); conf = get_config(t.id); conf.current_round += 1; pairs = swiss_pairing(t.id, conf.current_round)
    for i, (t1, t2) in enumerate(pairs):
        p1 = t1.players.replace('，',',').split(','); p2 = t2.players.replace('，',',').split(',')
        db.session.add(Match(tournament_id=t.id, round_no=conf.current_round, table_no=i+1, team_a_id=t1.id, team_b_id=t2.id, team_a_name=t1.name, team_b_name=t2.name, pos_west=p1[0], pos_east=p1[1] if len(p1)>1 else "P2", pos_north=p2[0], pos_south=p2[1] if len(p2)>1 else "P4"))
    db.session.commit(); log_act("开启新一轮", f"进入第 {conf.current_round} 轮", t.id); return redirect(url_for('matches'))

