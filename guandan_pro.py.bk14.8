@app.route('/export_excel')
def export_excel():
    t = get_active_t(); info = TournamentInfo.query.filter_by(tournament_id=t.id).first()
    if not info: info = TournamentInfo(tournament_id=t.id); db.session.add(info); db.session.commit()
    teams = Team.query.filter_by(tournament_id=t.id).all(); ms = Match.query.filter_by(tournament_id=t.id).all()
    # 恢复 V14.4 深度导出逻辑
    df_info = pd.DataFrame([{"赛事": t.name, "日期": info.t_date, "地点": info.t_location, "赞助商": info.t_sponsor}])
    df_teams = pd.DataFrame([{"排名": 0, "队名": m.name, "成员": m.players, "胜分": m.current_score, "级分": m.round_score} for m in teams]).sort_values(by=["胜分", "级分"], ascending=False)
    df_ms = pd.DataFrame([{"轮次": m.round_no, "桌号": m.table_no, "A队": m.team_a_name, "B队": m.team_b_name, "状态": "完赛" if m.is_completed else "未赛"} for m in ms])
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='openpyxl') as writer:
        df_info.to_excel(writer, sheet_name='赛事概况', index=False)
        df_teams.to_excel(writer, sheet_name='积分排行', index=False)
        df_ms.to_excel(writer, sheet_name='对战流水单', index=False)
    output.seek(0); log_act("导出 Excel", f"生成完整赛季报表", t.id)
    return send_file(output, as_attachment=True, download_name=f"{t.name}_V14_7_Backup.xlsx")

