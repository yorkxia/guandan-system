@app.route('/logs')
def logs():
    t = get_active_t(); ls = AuditLog.query.filter_by(tournament_id=t.id if t else None).order_by(AuditLog.timestamp.desc()).all()
    rows = "".join([f"<tr><td>{l.timestamp.strftime('%H:%M')}</td><td>{l.user}</td><td>{l.action}</td><td>{l.details}</td></tr>" for l in ls])
    return render_layout(f'<div class="card p-4"><h5>📊 审计日志</h5><table class="table table-dark table-sm mt-3">{rows}</table></div>', "logs")

@app.route('/init_game')
def init_game():
    t = get_active_t(); conf = get_config(t.id); conf.current_round = 1
    Match.query.filter_by(tournament_id=t.id).delete()
    ts = Team.query.filter_by(tournament_id=t.id).all(); random.shuffle(ts)
    for i in range(0, len(ts)-1, 2):
        t1, t2 = ts[i], ts[i+1]; p1 = t1.players.replace('，',',').split(','); p2 = t2.players.replace('，',',').split(',')
        db.session.add(Match(tournament_id=t.id, round_no=1, table_no=(i//2+1), team_a_id=t1.id, team_b_id=t2.id, team_a_name=t1.name, team_b_name=t2.name,
                             pos_east=p1[0], pos_west=p1[1] if len(p1)>1 else "A2", pos_north=p2[0], pos_south=p2[1] if len(p2)>1 else "B2"))
    db.session.commit(); return redirect(url_for('matches'))

@app.route('/new_start')
def new_start():
    Tournament.query.update({Tournament.is_active: False}); db.session.commit()
    return redirect(url_for('setup'))

@app.route('/view_history/<int:tid>')
def view_history(tid):
    Tournament.query.update({Tournament.is_active: False})
    t = Tournament.query.get(tid); t.is_active = True; db.session.commit()
    return redirect(url_for('setup'))

@app.route('/users', methods=['GET', 'POST'])
def users():
    if request.method == 'POST':
        db.session.add(User(username=request.form['u'], password=request.form['p'])); db.session.commit()
    us = User.query.all(); rows = "".join([f"<tr><td>{u.username}</td><td><a href='/del_u/{u.id}'>注销</a></td></tr>" for u in us])
    return render_layout(f'<div class="card p-4"><h5>管理员名单</h5><table class="table table-dark">{rows}</table><form method="post" class="mt-3"><input name="u" placeholder="账号" required><input name="p" type="password" placeholder="密码" required><button class="btn btn-info">添加管理员</button></form></div>', "users")

@app.route('/del_t/<int:tid>')
def del_t(tid): t = Team.query.get(tid); db.session.delete(t); db.session.commit(); return redirect(url_for('setup'))
@app.route('/del_u/<int:uid>')
def del_u(uid): u = User.query.get(uid); db.session.delete(u); db.session.commit(); return redirect(url_for('users'))
@app.route('/logout')
def logout(): session.clear(); return redirect(url_for('login'))

