@app.route('/export_excel')
def export_excel():
    t = get_active_t()
    info = get_t_info(t.id); teams = Team.query.filter_by(tournament_id=t.id).all()
    matches = Match.query.filter_by(tournament_id=t.id).all()
    
    # 构建数据表
    df_info = pd.DataFrame([{"赛事名称": t.name, "日期": info.t_date, "地点": info.t_location, "赞助商": info.t_sponsor, "备注": info.t_note}])
    df_teams = pd.DataFrame([{"排名": 0, "队名": m.name, "成员": m.players, "胜分": m.current_score, "级分": m.round_score} for m in teams])
    df_teams = df_teams.sort_values(by=["胜分", "级分"], ascending=False).assign(排名=range(1, len(teams)+1))
    df_matches = pd.DataFrame([{"轮次": m.round_no, "桌号": m.table_no, "队伍A": m.team_a_name, "队伍B": m.team_b_name, "状态": "完成" if m.is_completed else "未完"} for m in matches])
    
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='openpyxl') as writer:
        df_info.to_excel(writer, sheet_name='赛事资料', index=False)
        df_teams.to_excel(writer, sheet_name='排名备份', index=False)
        df_matches.to_excel(writer, sheet_name='全轮次对阵', index=False)
    
    output.seek(0)
    filename = f"{t.name}_备份_{datetime.now().strftime('%m%d_%H%M')}.xlsx"
    return send_file(output, as_attachment=True, download_name=filename)

