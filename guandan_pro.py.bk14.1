    conf = get_config(t.id); ms = Match.query.filter_by(tournament_id=t.id, round_no=conf.current_round).all()
    
    timer_html = """<div id="timer-box"><div class="text-center small text-secondary">MINS<br><input type="number" id="duration" class="bg-dark text-white border-0 text-center" style="width:50px" value="50"></div><div id="time-display">计时器</div><div class="btn-group gap-2"><button onclick="startTimer()" class="btn btn-success rounded-pill px-4">START</button><button onclick="pauseTimer()" class="btn btn-warning rounded-pill px-4">STOP</button></div></div>"""
