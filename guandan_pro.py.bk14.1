    next_btn = f'<div class="text-center mt-4"><a href="/next_r" class="btn btn-danger btn-lg px-5 py-3 fw-bold shadow">🏁 开启下一轮编排 (SWISS)</a></div>' if ms and all(m.is_completed for m in ms) else ""
    return render_layout(timer_html + f'<div class="row">{cards}</div>' + next_btn, "matches")

@app.route('/save/<int:mid>', methods=['POST'])
def save(mid):
    m = Match.query.get(mid); t1 = Team.query.get(m.team_a_id); t2 = Team.query.get(m.team_b_id)
    sa, sb = int(request.form.get('sa')), int(request.form.get('sb'))
    t1.round_score += sa; t2.round_score += sb
    if sa > sb: t1.current_score += 3; m.winner_id = t1.id
    elif sb > sa: t2.current_score += 3; m.winner_id = t2.id
    else: t1.current_score += 1; t2.current_score += 1 # 平局
    m.is_completed = True; t1.history_opponents = (t1.history_opponents + f",{t2.id}").strip(','); t2.history_opponents = (t2.history_opponents + f",{t1.id}").strip(',')
    db.session.commit(); log_act("录入成绩", f"桌号{m.table_no}: {sa}-{sb}", m.tournament_id); return redirect(url_for('matches'))

@app.route('/next_r')
def next_r():
    t = get_active_tournament(); conf = get_config(t.id)
    if conf.current_round >= conf.total_rounds: return "赛事已全部结束"
    conf.current_round += 1; pairs = swiss_pairing(t.id, conf.current_round)
    for i, (t1, t2) in enumerate(pairs):
        p1 = t1.players.replace('，',',').split(','); p2 = t2.players.replace('，',',').split(',')
        db.session.add(Match(tournament_id=t.id, round_no=conf.current_round, table_no=i+1, team_a_id=t1.id, team_b_id=t2.id, team_a_name=t1.name, team_b_name=t2.name,
                             pos_east=p1[0], pos_west=p1[1] if len(p1)>1 else "P2", pos_north=p2[0], pos_south=p2[1] if len(p2)>1 else "P4"))
    db.session.commit(); log_act("瑞士制编排", f"进入第 {conf.current_round} 轮", t.id); return redirect(url_for('matches'))

