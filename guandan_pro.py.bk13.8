        """
    return render_layout(f'<div class="row justify-content-center"><div class="col-md-9 card p-4"><h3 class="text-center text-info mb-4">🏆 当前总积分排名</h3><table class="table table-dark text-center table-hover"><thead><tr><th>排名</th><th>队名</th><th>总胜分</th><th>总级分</th></tr></thead><tbody>{rows}</tbody></table><button class="btn btn-warning w-100 py-3 mt-4 fw-bold" data-bs-toggle="modal" data-bs-target="#awardModal">🎉 颁奖大屏模式</button></div></div>' + award_modal, "leaderboard")

@app.route('/users', methods=['GET', 'POST'])
def users():
    if request.method == 'POST':
        db.session.add(User(username=request.form['u'], password=request.form['p'])); db.session.commit()
    us = User.query.all(); rows = "".join([f"<tr><td>{u.username}</td><td><a href='/del_u/{u.id}' class='text-danger'>删除</a></td></tr>" for u in us])
    return render_layout(f'<div class="row"><div class="col-md-4 card p-4"><h5>新增管理员</h5><form method="post" class="mt-3"><input name="u" class="form-control mb-2 bg-dark text-white"><input name="p" type="password" class="form-control mb-3 bg-dark text-white"><button class="btn btn-info w-100">保存</button></form></div><div class="col-md-8 px-4"><div class="card p-4"><h5>管理员名单</h5><table class="table table-dark mt-2"><tbody>{rows}</tbody></table></div></div></div>', "users")

@app.route('/logs')
def logs():
    t = get_active_tournament()
    ls = AuditLog.query.filter_by(tournament_id=t.id if t else None).order_by(AuditLog.timestamp.desc()).limit(100).all()
    rows = "".join([f"<tr><td>{l.timestamp.strftime('%H:%M:%S')}</td><td>{l.user}</td><td>{l.action}</td><td>{l.details}</td></tr>" for l in ls])
    return render_layout(f'<div class="card p-4"><h4>📊 审计日志</h4><table class="table table-dark small mt-3"><tbody>{rows}</tbody></table></div>', "logs")

@app.route('/del_t/<int:tid>')
def del_t(tid): 
    t = Team.query.get(tid); db.session.delete(t); db.session.commit(); return redirect(url_for('setup'))

@app.route('/del_u/<int:uid>')
def del_u(uid): 
    u = User.query.get(uid)
    if u.username != 'admin': db.session.delete(u); db.session.commit()
    return redirect(url_for('users'))

@app.route('/logout')
def logout(): session.clear(); return redirect(url_for('login'))

if __name__ == '__main__':
    with app.app_context():
        db.create_all()
        # 初始化管理员
