@app.route('/new_start')
def new_start():
    Tournament.query.update({Tournament.is_active: False}); db.session.commit()
    return redirect(url_for('setup'))

@app.route('/view_history/<int:tid>')
def view_history(tid):
    Tournament.query.update({Tournament.is_active: False})
    t = Tournament.query.get(tid)
    t.is_active = True
    db.session.commit()
    return redirect(url_for('leaderboard'))

@app.route('/init_game')
def init_game():
    t = get_active_tournament()
    if not t: return redirect(url_for('setup'))
    conf = get_config(t.id); conf.current_round = 1
    Match.query.filter_by(tournament_id=t.id).delete()
    ts = Team.query.filter_by(tournament_id=t.id).all(); random.shuffle(ts)
    for i in range(0, len(ts)-1, 2):
        t1, t2 = ts[i], ts[i+1]; p1 = t1.players.replace('，',',').split(','); p2 = t2.players.replace('，',',').split(',')
        db.session.add(Match(tournament_id=t.id, round_no=1, table_no=(i//2+1), team_a_id=t1.id, team_b_id=t2.id, team_a_name=t1.name, team_b_name=t2.name,
                             pos_east=p1[0], pos_west=p1[1] if len(p1)>1 else "A2", pos_north=p2[0], pos_south=p2[1] if len(p2)>1 else "B2"))
    db.session.commit(); log_act("赛事启动", "生成首轮随机对阵", t.id); return redirect(url_for('matches'))

